{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/gids/wateraccu",
      "destination": "/kennisbank/wateraccu",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/data/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=900" }
      ]
    }
  ]
}
